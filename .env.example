# Application
APP_PORT=3000
APP_ENV=development
APP_NAME=EasyRisparmio

# Database (local Docker PostgreSQL — see docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/easyresparmio
DB_SSL=false

# Database (NeonDB — for production/staging)
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/easyresparmio?sslmode=require
# DB_SSL=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760

# Frontend URLs (for CORS)
FRONTEND_URL=http://localhost:3001
MOBILE_APP_SCHEME=easyresparmio

# Email — SMTP (Mailhog for dev, leave SMTP_HOST empty in production)
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=EasyRisparmio <noreply@easyresparmio.it>

# Email — Resend (production, ignored when SMTP_HOST is set)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OTP
OTP_EXPIRY_MINUTES=10

# Firebase (Social Login)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Admin Seed
ADMIN_EMAIL=admin@easyresparmio.it
ADMIN_PASSWORD=ChangeThisSecurePassword123!

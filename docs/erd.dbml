// ===== ENUMS =====

Enum user_role {
  personal
  business
  admin
  agent
}

Enum user_status {
  active
  inactive
  suspended
  pending_verification
}

Enum otp_type {
  email_verification
  phone_verification
  password_reset
}

Enum bill_type {
  electricity
  gas
}

Enum bill_status {
  uploaded
  analyzing
  analyzed
  error
}

Enum energy_type {
  electricity
  gas
  dual
}

Enum market_type {
  fixed
  variable
  indexed
}

Enum user_target {
  personal
  business
  both
}

Enum case_status {
  new
  in_progress
  documents_pending
  contract_sent
  contract_signed
  activated
  rejected
  cancelled
}

Enum case_priority {
  low
  medium
  high
  urgent
}

Enum case_type {
  switch
  transfer
  takeover
  new_activation
}

Enum contract_status {
  draft
  sent
  signed
  active
  expired
  cancelled
}

Enum commission_status {
  pending
  approved
  paid
}

Enum commission_type {
  activation
  renewal
}

Enum commission_calc_type {
  per_pod
  per_mwh
  percentage
  flat
}

Enum document_type {
  bill
  id_card
  codice_fiscale
  contract
  signed_contract
  partita_iva
}

Enum ticket_status {
  open
  in_progress
  resolved
  closed
}

Enum ticket_priority {
  low
  medium
  high
  urgent
}

Enum ticket_category {
  technical_support
  billing_payments
  switching
  general
}

Enum notification_type {
  bill_analyzed
  offer_available
  case_update
  contract_status
  general
}

Enum platform {
  ios
  android
}

Enum utility_type {
  electricity
  gas
  water
  internet
}

Enum meter_status {
  active
  inactive
  pending
  terminated
}

Enum address_type {
  residential
  supply
  legal
  billing
}

Enum payment_method {
  rid_bancario
  credit_card
  postal_order
  bank_transfer
}

Enum invoice_delivery {
  digital
  paper
}

Enum language_pref {
  italiano
  english
}

Enum offer_status {
  draft
  active
  expiring
  expired
  archived
}

Enum case_event_type {
  status_change
  document_uploaded
  document_verified
  agent_assigned
  note_added
  message_sent
  ocr_completed
  contract_generated
  contract_signed
  system_event
}

Enum alert_type {
  duplicate_pod
  contract_expiring
  ocr_verification
  high_value_lead
  sla_breach
  missing_documents
}

Enum alert_severity {
  info
  warning
  critical
}

Enum alert_status {
  active
  acknowledged
  resolved
  dismissed
}

Enum reconciliation_status {
  pending
  processing
  completed
  failed
}

Enum recon_row_status {
  matched
  not_found
  error
  ignored
  manually_matched
}

Enum referral_status {
  pending
  registered
  qualified
  rewarded
  expired
}

// ===== DOMAIN A: AUTH =====

Table users [headercolor: #3498db] {
  id uuid [pk, default: `gen_random_uuid()`]
  email varchar(255) [unique, not null]
  phone varchar(20)
  password_hash varchar(255) [not null]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  codice_fiscale varchar(16)
  avatar varchar(500)
  role user_role [not null, default: 'personal']
  status user_status [not null, default: 'pending_verification']
  email_verified boolean [not null, default: false]
  phone_verified boolean [not null, default: false]
  last_login_at timestamptz
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    email [unique]
    phone
    (role, status)
    codice_fiscale
  }

  Note: 'Core user table. Supports personal, business, admin, agent roles. Soft-deletable via deleted_at.'
}

Table refresh_tokens [headercolor: #3498db] {
  id uuid [pk, default: `gen_random_uuid()`]
  token varchar(500) [not null]
  expires_at timestamptz [not null]
  revoked boolean [not null, default: false]
  device_info varchar(500)
  ip_address varchar(45)
  user_id uuid [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    token
    user_id
    (user_id, revoked)
  }
}

Table otp_codes [headercolor: #3498db] {
  id uuid [pk, default: `gen_random_uuid()`]
  code varchar(6) [not null]
  type otp_type [not null]
  expires_at timestamptz [not null]
  used boolean [not null, default: false]
  attempts smallint [not null, default: 0]
  user_id uuid [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    type
    user_id
    (user_id, type, used)
  }
}

// ===== DOMAIN B: USER PROFILES =====

Table business_profiles [headercolor: #2ecc71] {
  id uuid [pk, default: `gen_random_uuid()`]
  company_name varchar(255) [not null]
  partita_iva varchar(11) [unique, not null]
  pec_email varchar(255)
  legal_representative varchar(255)
  company_type varchar(100)
  ateco_code varchar(10)
  employee_count int
  annual_revenue_range varchar(50)
  user_id uuid [unique, not null, ref: - users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Business-specific profile data. One-to-one with users where role=business.'
}

Table user_addresses [headercolor: #2ecc71] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  address_type address_type [not null, default: 'residential']
  street_address varchar(255) [not null]
  city varchar(100) [not null]
  province varchar(2) [note: 'Italian province code (TO, MI, RM)']
  postal_code varchar(10) [not null]
  country varchar(2) [not null, default: 'IT']
  is_primary boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    (user_id, is_primary)
  }

  Note: 'NEW - Figma Gap #1. Users may have multiple addresses (residential, supply, billing).'
}

Table user_preferences [headercolor: #2ecc71] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [unique, not null, ref: - users.id]
  payment_method payment_method [default: 'rid_bancario']
  invoice_delivery invoice_delivery [default: 'digital']
  language language_pref [not null, default: 'italiano']
  contact_preference varchar(20) [default: 'email']
  marketing_consent boolean [not null, default: false]
  gdpr_consent_at timestamptz
  iban varchar(34)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'NEW - Figma Gap #2. Payment method, invoice type, language preferences.'
}

Table user_agent_assignments [headercolor: #2ecc71] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  agent_id uuid [not null, ref: > users.id]
  assigned_at timestamptz [not null, default: `now()`]
  is_active boolean [not null, default: true]
  assigned_by_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    agent_id
    (user_id) [unique, note: 'One active assignment per client']
  }

  Note: 'NEW - Tracks which agent/operator is assigned to each client.'
}

// ===== DOMAIN C: ENERGY / BILLS =====

Table meters [headercolor: #e67e22] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  utility_type utility_type [not null]
  meter_code varchar(50) [not null, note: 'POD for electricity, PDR for gas']
  supplier_id uuid [ref: > suppliers.id]
  status meter_status [not null, default: 'active']
  annual_consumption decimal(12,2)
  consumption_unit varchar(20) [note: 'kWh, Smc, Liters, GB']
  contracted_power_kw decimal(8,2)
  address_id uuid [ref: > user_addresses.id]
  activation_date date
  notes text
  deleted_at timestamptz
  created_by uuid [ref: > users.id]
  updated_by uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    supplier_id
    meter_code
    utility_type
    (meter_code, utility_type) [unique, note: 'No duplicate active meters']
  }

  Note: 'NEW - Figma Gap #3. Meter/utility point registry. Central entity linking POD/PDR to users.'
}

Table energy_bills [headercolor: #e67e22] {
  id uuid [pk, default: `gen_random_uuid()`]
  file_url varchar(500) [not null]
  bill_type bill_type [not null]
  status bill_status [not null, default: 'uploaded']
  pod_number varchar(50)
  pdr_number varchar(50)
  billing_period_start date
  billing_period_end date
  total_amount decimal(10,2)
  consumption_kwh decimal(10,2)
  consumption_smc decimal(10,2)
  cost_per_unit decimal(10,6)
  fixed_charges decimal(10,2)
  taxes decimal(10,2)
  raw_analysis_data jsonb
  user_id uuid [not null, ref: > users.id]
  supplier_id uuid [ref: > suppliers.id]
  meter_id uuid [ref: > meters.id]
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    supplier_id
    meter_id
    status
    (user_id, status)
    pod_number
    pdr_number
  }
}

Table bill_analyses [headercolor: #e67e22] {
  id uuid [pk, default: `gen_random_uuid()`]
  potential_savings decimal(10,2) [not null]
  current_monthly_avg decimal(10,2) [not null]
  recommended_market_type market_type [not null]
  analysis_summary text [not null]
  analysis_details jsonb
  confidence_score decimal(5,2) [note: 'OCR confidence 0-100']
  recommended_offers jsonb [note: 'Array of {offer_id, savings_estimate}']
  bill_id uuid [unique, not null, ref: - energy_bills.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

// ===== DOMAIN D: SUPPLIERS / OFFERS =====

Table suppliers [headercolor: #9b59b6] {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(255) [not null]
  supplier_code varchar(50) [unique, note: 'Internal code e.g. ENEL, SORG']
  logo_url varchar(500)
  description text
  rating decimal(3,2) [not null, default: 0]
  is_active boolean [not null, default: true]
  contact_email varchar(255)
  contact_phone varchar(20)
  website varchar(500)
  deleted_at timestamptz
  created_by uuid [ref: > users.id]
  updated_by uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (is_active)
  }
}

Table offers [headercolor: #9b59b6] {
  id uuid [pk, default: `gen_random_uuid()`]
  offer_code varchar(50) [note: 'Human-readable ID e.g. OFF-001']
  name varchar(255) [not null]
  description text
  energy_type energy_type [not null]
  market_type market_type [not null]
  price_per_kwh decimal(10,6)
  price_per_smc decimal(10,6)
  fixed_monthly_fee decimal(10,2) [not null, default: 0]
  activation_cost decimal(10,2) [not null, default: 0]
  contract_duration_months int [not null]
  is_green_energy boolean [not null, default: false]
  is_active boolean [not null, default: true]
  status offer_status [not null, default: 'draft']
  valid_from date [not null]
  valid_until date
  terms_url varchar(500)
  target user_target [not null, default: 'both']
  highlights jsonb [note: 'String array of bullet points']
  version int [not null, default: 1]
  parent_offer_id uuid [ref: > offers.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  deleted_at timestamptz
  created_by uuid [ref: > users.id]
  updated_by uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    supplier_id
    energy_type
    (supplier_id, energy_type)
    status
    target
    (is_active, valid_from, valid_until)
    parent_offer_id
  }
}

Table offer_price_versions [headercolor: #9b59b6] {
  id uuid [pk, default: `gen_random_uuid()`]
  offer_id uuid [not null, ref: > offers.id]
  version_label varchar(20) [not null, note: 'e.g. v2.4, v2.3']
  price_per_kwh decimal(10,6)
  price_per_smc decimal(10,6)
  fixed_monthly_fee decimal(10,2)
  activation_cost decimal(10,2)
  valid_from date [not null]
  valid_until date
  is_current boolean [not null, default: false]
  price_data jsonb [note: 'Full tier/component breakdown']
  created_by uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    offer_id
    (offer_id, is_current)
  }

  Note: 'NEW - Figma Gap #10. Price list version history per offer.'
}

// ===== DOMAIN E: CASES / CONTRACTS =====

Table switch_cases [headercolor: #e74c3c] {
  id uuid [pk, default: `gen_random_uuid()`]
  case_number varchar(20) [unique, not null, note: 'Human-readable e.g. PR-0247']
  case_type case_type [not null, default: 'switch']
  user_id uuid [not null, ref: > users.id]
  bill_id uuid [not null, ref: > energy_bills.id]
  selected_offer_id uuid [not null, ref: > offers.id]
  assigned_agent_id uuid [ref: > users.id]
  status case_status [not null, default: 'new']
  priority case_priority [not null, default: 'medium']
  notes text
  internal_notes text
  sla_deadline timestamptz
  sla_days_total int
  estimated_annual_value decimal(12,2) [note: 'For High Value Lead alert']
  from_supplier_id uuid [ref: > suppliers.id]
  to_supplier_id uuid [ref: > suppliers.id]
  meter_id uuid [ref: > meters.id]
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    case_number [unique]
    user_id
    status
    assigned_agent_id
    (status, user_id)
    (status, assigned_agent_id)
    case_type
    priority
    sla_deadline
  }

  Note: 'Central switching case entity. Tracks entire provider-switch lifecycle.'
}

Table case_documents [headercolor: #e74c3c] {
  id uuid [pk, default: `gen_random_uuid()`]
  case_id uuid [not null, ref: > switch_cases.id]
  document_type document_type [not null]
  file_url varchar(500) [not null]
  file_name varchar(255) [not null]
  file_size_bytes bigint
  mime_type varchar(100)
  uploaded_by_id uuid [not null, ref: > users.id]
  verified boolean [not null, default: false]
  verified_by_id uuid [ref: > users.id]
  verified_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    case_id
    uploaded_by_id
    document_type
  }
}

Table case_events [headercolor: #e74c3c] {
  id uuid [pk, default: `gen_random_uuid()`]
  case_id uuid [not null, ref: > switch_cases.id]
  event_type case_event_type [not null]
  title varchar(255) [not null]
  description text
  old_status case_status
  new_status case_status
  actor_id uuid [ref: > users.id]
  actor_label varchar(100) [note: 'System (OCR), Giuseppe Verdi']
  metadata jsonb
  created_at timestamptz [not null, default: `now()`]

  indexes {
    case_id
    event_type
    (case_id, created_at) [note: 'Timeline queries']
  }

  Note: 'NEW - Figma Gap #4. Append-only case timeline/audit trail.'
}

Table contracts [headercolor: #e74c3c] {
  id uuid [pk, default: `gen_random_uuid()`]
  case_id uuid [unique, not null, ref: - switch_cases.id]
  offer_id uuid [not null, ref: > offers.id]
  user_id uuid [not null, ref: > users.id]
  contract_number varchar(100) [unique, not null]
  status contract_status [not null, default: 'draft']
  pod_pdr_number varchar(50)
  activation_date date
  expiry_date date
  renewal_date date
  signed_at timestamptz
  signed_document_url varchar(500)
  monthly_estimate decimal(10,2)
  cancellation_reason text
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    case_id [unique]
    contract_number [unique]
    user_id
    offer_id
    status
    (user_id, status)
    expiry_date [note: 'Expiring contract alerts']
  }
}

// ===== DOMAIN F: COMMISSIONS =====

Table commissions [headercolor: #f39c12] {
  id uuid [pk, default: `gen_random_uuid()`]
  agent_id uuid [not null, ref: > users.id]
  case_id uuid [not null, ref: > switch_cases.id]
  offer_id uuid [not null, ref: > offers.id]
  supplier_id uuid [not null, ref: > suppliers.id]
  rule_id uuid [ref: > commission_rules.id]
  amount decimal(10,2) [not null]
  currency varchar(3) [not null, default: 'EUR']
  status commission_status [not null, default: 'pending']
  commission_type commission_type [not null, default: 'activation']
  approved_at timestamptz
  approved_by_id uuid [ref: > users.id]
  paid_at timestamptz
  notes text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    agent_id
    case_id
    supplier_id
    status
    (agent_id, status)
    paid_at
  }
}

Table commission_rules [headercolor: #f39c12] {
  id uuid [pk, default: `gen_random_uuid()`]
  supplier_id uuid [not null, ref: > suppliers.id]
  offer_id uuid [ref: > offers.id]
  energy_type energy_type [not null]
  target user_target [not null, default: 'both']
  commission_amount decimal(10,2) [not null]
  commission_percentage decimal(5,2)
  is_active boolean [not null, default: true]
  valid_from date [not null]
  valid_until date
  created_by uuid [ref: > users.id]
  updated_by uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    supplier_id
    (supplier_id, energy_type)
    (is_active, valid_from, valid_until)
  }
}

Table commission_tiers [headercolor: #f39c12] {
  id uuid [pk, default: `gen_random_uuid()`]
  rule_id uuid [not null, ref: > commission_rules.id]
  consumption_min_mwh decimal(10,2) [not null]
  consumption_max_mwh decimal(10,2) [note: 'NULL = unlimited upper bound']
  calc_type commission_calc_type [not null]
  acquisition_per_pod decimal(10,2)
  acquisition_per_mwh decimal(10,2)
  recurrent_base decimal(10,2) [note: 'Monthly recurrent base rate']
  recurrent_premium decimal(10,2) [note: 'Opz. Prime']
  recurrent_green decimal(10,2) [note: 'Energia Verde']
  recurrent_from_month int [not null, default: 1]
  recurrent_to_month int [note: 'NULL = indefinite']
  sort_order int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    rule_id
    (rule_id, sort_order)
  }

  Note: 'NEW - Figma Gap #11. Consumption-based commission bands with tiered rates.'
}

// ===== DOMAIN G: SUPPORT =====

Table support_tickets [headercolor: #1abc9c] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  assigned_agent_id uuid [ref: > users.id]
  subject varchar(255) [not null]
  category ticket_category [not null, default: 'general']
  priority ticket_priority [not null, default: 'medium']
  status ticket_status [not null, default: 'open']
  resolved_at timestamptz
  closed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    assigned_agent_id
    status
    (status, priority)
  }
}

Table ticket_messages [headercolor: #1abc9c] {
  id uuid [pk, default: `gen_random_uuid()`]
  ticket_id uuid [not null, ref: > support_tickets.id]
  sender_id uuid [not null, ref: > users.id]
  message text [not null]
  attachments jsonb [note: 'String array of file URLs']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    ticket_id
    sender_id
    (ticket_id, created_at)
  }
}

Table faqs [headercolor: #1abc9c] {
  id uuid [pk, default: `gen_random_uuid()`]
  category varchar(100) [not null]
  question varchar(500) [not null]
  answer text [not null]
  sort_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  locale varchar(5) [not null, default: 'it']
  target_audience user_target [not null, default: 'both']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    category
    (is_active, sort_order)
  }
}

// ===== DOMAIN H: NOTIFICATIONS =====

Table notifications [headercolor: #34495e] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  title varchar(255) [not null]
  body text [not null]
  type notification_type [not null, default: 'general']
  data jsonb
  is_read boolean [not null, default: false]
  read_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    (user_id, is_read) [note: 'Fast unread count']
    (created_at) [note: 'Partition-ready for archival']
  }

  Note: 'High-volume table. Candidate for range partitioning on created_at.'
}

Table push_tokens [headercolor: #34495e] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null, ref: > users.id]
  token varchar(500) [unique, not null]
  platform platform [not null]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    token [unique]
    (user_id, is_active)
  }
}

// ===== DOMAIN I: MARKET DATA =====

Table market_indices [headercolor: #7f8c8d] {
  id uuid [pk, default: `gen_random_uuid()`]
  index_name varchar(50) [not null, note: 'PUN, GME, PSV']
  value decimal(12,4) [not null]
  unit varchar(20) [not null, note: 'EUR/MWh, EUR/Smc']
  date date [not null]
  source varchar(100) [note: 'GME, ARERA']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (index_name, date) [unique]
    (date)
  }

  Note: 'Italian energy market price indices. PUN = Prezzo Unico Nazionale.'
}

// ===== DOMAIN J: SYSTEM / ADMIN =====

Table activity_logs [headercolor: #95a5a6] {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [ref: > users.id, note: 'NULL for system actions']
  action varchar(255) [not null]
  entity_type varchar(100) [not null]
  entity_id varchar(255)
  metadata jsonb
  ip_address varchar(45)
  user_agent varchar(500)
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    (entity_type, entity_id)
    action
    (created_at) [note: 'Partition-ready']
  }

  Note: 'Append-only audit trail. No updated_at. Candidate for monthly partitioning.'
}

Table admin_alerts [headercolor: #95a5a6] {
  id uuid [pk, default: `gen_random_uuid()`]
  alert_type alert_type [not null]
  severity alert_severity [not null, default: 'info']
  status alert_status [not null, default: 'active']
  title varchar(255) [not null]
  description text
  entity_type varchar(100)
  entity_id uuid
  related_data jsonb
  acknowledged_by_id uuid [ref: > users.id]
  acknowledged_at timestamptz
  resolved_by_id uuid [ref: > users.id]
  resolved_at timestamptz
  expires_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    status
    (alert_type, status)
    (entity_type, entity_id)
    severity
  }

  Note: 'NEW - Figma Gap #8. Duplicate POD, contract expiring, OCR verification, high value lead alerts.'
}

Table csv_reconciliations [headercolor: #95a5a6] {
  id uuid [pk, default: `gen_random_uuid()`]
  supplier_id uuid [ref: > suppliers.id]
  file_url varchar(500) [not null]
  file_name varchar(255) [not null]
  status reconciliation_status [not null, default: 'pending']
  total_rows int [not null, default: 0]
  successful_matches int [not null, default: 0]
  not_found_count int [not null, default: 0]
  error_count int [not null, default: 0]
  total_value decimal(12,2)
  processing_started_at timestamptz
  processing_completed_at timestamptz
  uploaded_by_id uuid [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    supplier_id
    status
    uploaded_by_id
  }

  Note: 'NEW - Figma Gap #7. CSV upload for POD/status reconciliation against supplier data.'
}

Table csv_reconciliation_rows [headercolor: #95a5a6] {
  id uuid [pk, default: `gen_random_uuid()`]
  reconciliation_id uuid [not null, ref: > csv_reconciliations.id]
  row_number int [not null]
  csv_pod varchar(50) [not null]
  csv_status varchar(50) [not null, note: 'Paid, Unpaid, etc.']
  csv_raw_data jsonb
  status recon_row_status [not null, default: 'matched']
  matched_meter_id uuid [ref: > meters.id]
  matched_contract_id uuid [ref: > contracts.id]
  possible_match_info varchar(500)
  error_message text
  resolved_by_id uuid [ref: > users.id]
  resolved_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    reconciliation_id
    csv_pod
    status
    (reconciliation_id, status)
  }
}

Table referrals [headercolor: #95a5a6] {
  id uuid [pk, default: `gen_random_uuid()`]
  referrer_id uuid [not null, ref: > users.id]
  referral_code varchar(20) [unique, not null]
  referred_email varchar(255)
  referred_phone varchar(20)
  referred_user_id uuid [ref: > users.id]
  status referral_status [not null, default: 'pending']
  reward_amount decimal(10,2)
  reward_credited_at timestamptz
  expires_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    referrer_id
    referral_code [unique]
    referred_user_id
    status
  }

  Note: 'NEW - Figma Gap #9. Invite & Earn referral program.'
}

Table agreements [headercolor: #95a5a6] {
  id uuid [pk, default: `gen_random_uuid()`]
  title varchar(255) [not null]
  description text
  partner_name varchar(255) [not null]
  partner_logo_url varchar(500)
  discount_description text
  terms_url varchar(500)
  is_active boolean [not null, default: true]
  target_audience user_target [not null, default: 'both']
  valid_from date [not null]
  valid_until date
  sort_order int [not null, default: 0]
  created_by uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (is_active, valid_from)
  }

  Note: 'NEW - Exclusive partner discounts shown in mobile app.'
}
